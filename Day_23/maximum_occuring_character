#include<iostream>
#include<map>
using namespace std;
int main(){
    string s;
    getline(cin,s);
    int count=0;
    char c;
    map<char,int>m;
    for(int i=0;i<s.size();i++){
        m[s[i]]++;
    }
    for(auto it:m){
        if(it.second>count){
            count=it.second;
            c=it.first;
        }
    }
    cout<<c;
}
