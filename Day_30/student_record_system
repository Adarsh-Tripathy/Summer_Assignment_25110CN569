#include<iostream>
using namespace std;
int main(){
    int roll[50];
    string name[50];
    float marks[50];
    int count=0;
    int choice;
    cout<<"STUDENT RECORD SYSTEM"<<endl;
    while(true){
        cout<<endl;
        cout<<"1. Add Student"<<endl;
        cout<<"2. Display Students"<<endl;
        cout<<"3. Search Student"<<endl;
        cout<<"4. Delete Student"<<endl;
        cout<<"5. Exit"<<endl;
        cout<<"Enter choice: ";
        cin>>choice;
        if(choice==1){
            cout<<"Enter Roll No: ";
            cin>>roll[count];
            cout<<"Enter Name: ";
            cin>>name[count]; // no spaces for now
            cout<<"Enter Marks: ";
            cin>>marks[count];
            count=count+1;
            cout<<"Student added successfully"<<endl;
        }
        if(choice==2){
            if(count==0){
                cout<<"No records found"<<endl;
            }
            else{
                cout<<"Roll  Name  Marks"<<endl;
                for(int i=0;i<count;i++){
                    cout<<roll[i]<<"  "<<name[i]<<"  "<<marks[i]<<endl;
                }
            }
        }
        if(choice==3){
            int sroll;
            cout<<"Enter Roll No to search: ";
            cin>>sroll;
            int found=0;
            for(int i=0;i<count;i++){
                if(roll[i]==sroll){
                    cout<<"Name: "<<name[i]<<endl;
                    cout<<"Marks: "<<marks[i]<<endl;
                    found=1;
                }
            }
            if(found==0){
                cout<<"Student not found"<<endl;
            }
        }
        if(choice==4){
            int sroll;
            cout<<"Enter Roll No to delete: ";
            cin>>sroll;
            int pos=-1;
            for(int i=0;i<count;i++){
                if(roll[i]==sroll){
                    pos=i;
                    break;
                }
            }
            if(pos==-1){
                cout<<"Student not found"<<endl;
            }
            else{
                for(int i=pos;i<count-1;i++){
                    roll[i]=roll[i+1];
                    name[i]=name[i+1];
                    marks[i]=marks[i+1];
                }
                count=count-1;
                cout<<"Student deleted successfully"<<endl;
            }
        }
        if(choice==5){
            cout<<"Exiting..."<<endl;
            break;
        }
    }
    return 0;
}
