#include<iostream>
#include<ctime>
#include<cstdlib>
using namespace std;
int main(){
    srand(time(0));
    int number=rand()%100 + 1;
    int guess;
    cout<<"||GUESS THE NUMBER||"<<endl;
    while(true){
        cin>>guess;
        if(guess>number){
            cout<<"Too high number"<<endl;
        }
        else if(number>guess){
            cout<<"Too low"<<endl;
        }
        else{
            cout<<"correct";
            break;
        }
    }
}
