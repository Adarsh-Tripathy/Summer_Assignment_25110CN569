#include<bits/stdc++.h>
using namespace std;
int main(){
  int n;
  cin>>n;
  if(n<0){
    cout<<"invalid number";
    return 0;
  }
  else if(n==0 || n==1){
    cout<<"not prime";
    return 0;
  }
  else{
    bool prime=true;
    for(int i=2;i<=n/2;i++){
      if(n%i==0){
        prime=false;
        break;
      }
    }
    if(prime==true) cout<<"prime";
    else cout<<"not prime";
  }
}
