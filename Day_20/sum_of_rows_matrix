#include<iostream>
using namespace std;
int main(){
    int n,a;
    cin>>n;
    cin>>a;
    int m[n][a];
    for(int i=0;i<n;i++){
        for(int j=0;j<a;j++){
            cin>>m[i][j];
        }
    }
    for(int i=0;i<n;i++){
        int sum=0;
        for(int j=0;j<a;j++){
            sum+=m[i][j];
        }
        cout<<"sum of "<<i+1<<" row is "<<sum;
        cout<<endl;
    }
}
