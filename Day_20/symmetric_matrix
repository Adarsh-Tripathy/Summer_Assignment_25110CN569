#include<iostream>
using namespace std;
int main(){
    int n;
    cin>>n;
    int m[n][n];
    for(int i=0;i<n;i++){
        for(int j=0;j<n;j++){
            cin>>m[i][j];
        }
    }
    int flag=0;
    for(int i=0;i<n;i++){
        for(int j=0;j<n;j++){
            if(m[i][j]==m[j][i]){
                continue;
            }
            else{
                flag=1;
                break;
            }

        }
    }
    if(flag==0){
        cout<<"symmetric matrix";
    }
    else cout<<"not symmetric";
}
