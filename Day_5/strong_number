#include<bits/stdc++.h>
int main(){
    int n;
    cin>>n;
    int a=n;
    int sum=0;
    while(n>0){
        int b=n%10;
        int fact=1;
        for(int i=b;i>0;i--){
            fact=fact*i;
        }
        sum+=fact;
        n=n/10;
    }
    if(sum==a) cout<<"strong number";
    else cout<<"not strong number";

}
