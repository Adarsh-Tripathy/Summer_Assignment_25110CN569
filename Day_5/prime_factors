#include<bits/stdc++.h>
using namespace std;
int main(){
    init_code();
    int n;
    cin>>n;
    for(int i=1;i<=n;i++){
        if(n%i==0){
            int flag=0;
            if(i==1)
                continue;
            for(int j=2;j<=i/2;j++){
                if(i%j==0){
                    flag=1;
                    break;
                }
            }
            if(flag==0){
                cout<<i<<endl;
            }
        }
    }
    return 0;
}
