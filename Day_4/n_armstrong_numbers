#include<bits/stdc++.h>
using namespace std;
int main(){
  int n;
  cin>>n;
  for(int i=0;i<n;i++){
    if(i==0 || i==1){
      cout<<i<<" ";
      continue;
    }
    else{
      int a,b,c=0;
      a=i;
      int temp=i;
      while(temp>0){
        b=temp%10;
        c+=pow(b,3);
        temp=temp/10;
      }
      if(c==a){
        cout<<a<<" ";
        continue;
      }
    }
  }
}
