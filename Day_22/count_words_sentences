#include<iostream>
#include<algorithm>
using namespace std;
int main(){
    string str;
    getline(cin,str);
    if(str.empty()){
        cout<<0;
        return 0;
    }
    int count=0;
    for(int i=0;i<str.size();i++){
        if(str[i] !=' ' && (i==0 || str[i-1]==' ')){
            count++;
        }
    }
    cout<<count;
}
