#include<iostream>
#include<vector>
using namespace std;
int main(){
    int a;
    cin>>a;
    vector<int>v(a);
    for(int i=0;i<a;i++){
        cin>>v[i];
    }
    int b;
    cin>>b;
    vector<int>v2(b);
    for(int i=0;i<b;i++){
        cin>>v2[i];
    }
    v.insert(v.end(),v2.begin(),v2.end());
    for(auto it:v){
        cout<<it<<" ";
    }
}
