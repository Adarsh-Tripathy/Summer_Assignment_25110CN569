#include<iostream>
#include<vector>
#include<unordered_set>
using namespace std;
int main(){
    int a;
    cin>>a;
    vector<int>v(a);
    unordered_set<int>s;
    for(int i=0;i<a;i++){
        cin>>v[i];
        s.insert(v[i]);
    }
    int b;
    cin>>b;
    vector<int>v2(b);
    for(int i=0;i<b;i++){
        cin>>v2[i];
        s.insert(v2[i]);
    }
    
    for(auto it:s){
        cout<<it<<" ";
    }
    
}
