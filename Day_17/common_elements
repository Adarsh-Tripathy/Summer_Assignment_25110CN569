#include<iostream>
#include<vector>
#include<unordered_map>
using namespace std;
int main(){
    int a,b;
    cin>>a;
    cin>>b;
    vector<int>v(a);
    vector<int>v2(b);
    unordered_map<int,int>m;
    vector<int>v3;
    for(int i=0;i<a;i++){
        cin>>v[i];
        m[v[i]]=1;
    }
    for(int i=0;i<b;i++){
        cin>>v2[i];
        if(m[v2[i]]==1){
            m[v2[i]]=2;
        }
    }
    for(auto it:m){
        if(it.second==2){
            cout<<it.first<<" ";
        }
    }
}
