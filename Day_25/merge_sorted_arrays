#include<iostream>
#include<vector>
using namespace std;
int main(){
    int n,m;
    cin>>n;
    cin>>m;
    int a[n],b[m];
    for(int i=0;i<n;i++){
        cin>>a[i];
    }
    for(int i=0;i<m;i++){
        cin>>b[i];
    }
    vector<int>v;
    int i=0;
    int j=0;
    while(i<n && j<m){
        if(a[i]<=b[j]){
            v.emplace_back(a[i]);
            i++;
        }
        else{
            v.emplace_back(b[j]);
            j++;
        }
    }
    while(i<n){
        v.emplace_back(a[i]);
        i++;
    }
    while(j<m){
        v.emplace_back(b[j]);
        j++;
    }
    for(auto it:v){
        cout<<it<<" ";
    }
}
