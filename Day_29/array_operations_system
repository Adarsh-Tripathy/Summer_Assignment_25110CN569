#include<iostream>
using namespace std;
int main(){
    int arr[50];
    int n=0; // current size of array
    int choice;
    cout<<"MENU DRIVEN ARRAY OPERATIONS"<<endl;
    while(true){
        cout<<endl;
        cout<<"1. Insert Element"<<endl;
        cout<<"2. Display Array"<<endl;
        cout<<"3. Search Element"<<endl;
        cout<<"4. Delete Element"<<endl;
        cout<<"5. Find Maximum"<<endl;
        cout<<"6. Find Minimum"<<endl;
        cout<<"7. Sum of Elements"<<endl;
        cout<<"8. Exit"<<endl;
        cout<<"Enter choice: ";
        cin>>choice;
        if(choice==1){
            cout<<"Enter element to insert: ";
            cin>>arr[n];
            n=n+1;
            cout<<"Element inserted"<<endl;
        }
        if(choice==2){
            if(n==0){
                cout<<"Array is empty"<<endl;
            }
            else{
                cout<<"Array elements: ";
                for(int i=0;i<n;i++){
                    cout<<arr[i]<<" ";
                }
                cout<<endl;
            }
        }
        if(choice==3){
            int key;
            cout<<"Enter element to search: ";
            cin>>key;
            int found=0;
            for(int i=0;i<n;i++){
                if(arr[i]==key){
                    cout<<"Element found at position "<<(i+1)<<endl;
                    found=1;
                    break;
                }
            }
            if(found==0){
                cout<<"Element not found"<<endl;
            }
        }
        if(choice==4){
            int key;
            cout<<"Enter element to delete: ";
            cin>>key;
            int pos=-1;
            for(int i=0;i<n;i++){
                if(arr[i]==key){
                    pos=i;
                    break;
                }
            }
            if(pos==-1){
                cout<<"Element not found"<<endl;
            }
            else{
                for(int i=pos;i<n-1;i++){
                    arr[i]=arr[i+1];
                }
                n=n-1;
                cout<<"Element deleted"<<endl;
            }
        }
        if(choice==5){
            if(n==0){
                cout<<"Array is empty"<<endl;
            }
            else{
                int maxVal=arr[0];
                for(int i=1;i<n;i++){
                    if(arr[i]>maxVal){
                        maxVal=arr[i];
                    }
                }
                cout<<"Maximum element: "<<maxVal<<endl;
            }
        }
        if(choice==6){
            if(n==0){
                cout<<"Array is empty"<<endl;
            }
            else{
                int minVal=arr[0];
                for(int i=1;i<n;i++){
                    if(arr[i]<minVal){
                        minVal=arr[i];
                    }
                }
                cout<<"Minimum element: "<<minVal<<endl;
            }
        }
        if(choice==7){
            int sum=0;
            for(int i=0;i<n;i++){
                sum=sum+arr[i];
            }
            cout<<"Sum of elements: "<<sum<<endl;
        }
        if(choice==8){
            cout<<"Exiting..."<<endl;
            break;
        }
    }
    return 0;
}
