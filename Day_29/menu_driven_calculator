#include<iostream>
using namespace std;
int main(){
    float num1, num2, result;
    int choice;
    cout<<"MENU DRIVEN CALCULATOR"<<endl;
    while(true){
        cout<<endl;
        cout<<"1. Addition"<<endl;
        cout<<"2. Subtraction"<<endl;
        cout<<"3. Multiplication"<<endl;
        cout<<"4. Division"<<endl;
        cout<<"5. Exit"<<endl;
        cout<<"Enter choice: ";
        cin>>choice;
        if(choice==5){
            cout<<"Exiting..."<<endl;
            break;
        }
        if(choice<1 || choice>5){
            cout<<"Invalid choice"<<endl;
            continue;
        }
        cout<<"Enter first number: ";
        cin>>num1;
        cout<<"Enter second number: ";
        cin>>num2;
        if(choice==1){
            result=num1+num2;
            cout<<"Result: "<<result<<endl;
        }
        if(choice==2){
            result=num1-num2;
            cout<<"Result: "<<result<<endl;
        }
        if(choice==3){
            result=num1*num2;
            cout<<"Result: "<<result<<endl;
        }
        if(choice==4){
            if(num2==0){
                cout<<"Error! Cannot divide by zero"<<endl;
            }
            else{
                result=num1/num2;
                cout<<"Result: "<<result<<endl;
            }
        }
    }
    return 0;
}
