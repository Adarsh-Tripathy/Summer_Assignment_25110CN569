#include<iostream>
#include<vector>
using namespace std;
struct Student{
    int roll;
    string name;
    float marks;
};
int main(){
    vector<Student> students;
    int choice;
    do{
        cout<<"\n----- Student Record System -----\n";
        cout<<"1. Add Student\n";
        cout<<"2. Display All\n";
        cout<<"3. Search Student\n";
        cout<<"4. Update Student\n";
        cout<<"5. Delete Student\n";
        cout<<"6. Exit\n";
        cout<<"Enter your choice: ";
        cin>>choice;
        if(choice==1){
            Student s;
            cout<<"Roll No: ";
            cin>>s.roll;
            cout<<"Name (no spaces pls): ";
            cin>>s.name;  // not handling spaces for now
            cout<<"Marks: ";
            cin>>s.marks;
            students.push_back(s);
            cout<<"Added!\n";
        }
        else if(choice==2){
            if(students.size()==0){
                cout<<"No data yet.\n";
            }
            else{
                cout<<"\nRoll\tName\tMarks\n";
                for(int i=0;i<students.size();i++){
                    cout<<students[i].roll<<"\t"<<students[i].name<<"\t"<<students[i].marks<<"\n";
                }
            }
        }
        else if(choice==3){
            int r;
            cout<<"Enter roll to search: ";
            cin>>r;
            bool found=false;
            for(int i=0;i<students.size();i++){
                if(students[i].roll==r){
                    cout<<"Found -> "<<students[i].name<<" | "<<students[i].marks<<"\n";
                    found=true;
                    break;
                }
            }
            if(!found) cout<<"Not found bro.\n";
        }
        else if(choice==4){
            int r;
            cout<<"Roll to update: ";
            cin>>r;
            bool found=false;
            for(int i=0;i<students.size();i++){
                if(students[i].roll==r){
                    cout<<"New name: ";
                    cin>>students[i].name;
                    cout<<"New marks: ";
                    cin>>students[i].marks;
                    found=true;
                    cout<<"Updated.\n";
                    break;
                }
            }
            if(!found) cout<<"No such record.\n";
        }
        else if(choice==5){
            int r;
            cout<<"Roll to delete: ";
            cin>>r;
            bool found=false;
            for(int i=0;i<students.size();i++){
                if(students[i].roll==r){
                    students.erase(students.begin()+i);
                    found=true;
                    cout<<"Deleted.\n";
                    break;
                }
            }
            if(!found) cout<<"No such roll no.\n";
        }
        else if(choice!=6){
            cout<<"Invalid choice, try again.\n";
        }
    }while(choice!=6);
    cout<<"Bye!\n";
    return 0;
}
