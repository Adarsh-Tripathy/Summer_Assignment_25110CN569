#include<iostream>
using namespace std;
int main(){
    int id[50];
    string name[50];
    float salary[50];
    int count=0;
    int choice;
    cout<<"EMPLOYEE MANAGEMENT SYSTEM"<<endl;
    while(true){
        cout<<endl;
        cout<<"1. Add Employee"<<endl;
        cout<<"2. Show Employees"<<endl;
        cout<<"3. Search Employee"<<endl;
        cout<<"4. Exit"<<endl;
        cout<<"Enter choice: ";
        cin>>choice;
        if(choice==1){
            cout<<"Enter ID:";
            cin>>id[count];
            cout<<"Enter Name:";
            cin>>name[count];
            cout<<"Enter Salary:";
            cin>>salary[count];
            count=count+1;
            cout<<"Employee Added"<<endl;
        }
        if(choice==2){
            cout<<"ID  Name  Salary"<<endl;
            for(int i=0;i<count;i++){
                cout<<id[i]<<"  "<<name[i]<<"  "<<salary[i]<<endl;
            }
        }
        if(choice==3){
            int sid;
            cout<<"Enter ID to search: ";
            cin>>sid;
            int found=0;
            for(int i=0;i<count;i++){
                if(id[i]==sid){
                    cout<<"Name: "<<name[i]<<endl;
                    cout<<"Salary: "<<salary[i]<<endl;
                    found=1;
                }
            }
            if(found==0){
                cout<<"Employee not found"<<endl;
            }
        }
        if(choice==4){
            cout<<"Exiting program..."<<endl;
            break;
        }
    }
    return 0;
}
