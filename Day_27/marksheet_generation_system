#include<iostream>
using namespace std;
int main(){
    int roll[50];
    string name[50];
    float sub1[50];
    float sub2[50];
    float sub3[50];
    float sub4[50];
    float sub5[50];
    float total[50];
    float percentage[50];
    string grade[50];
    int count=0;
    int choice;
    cout<<"MARKSHEET GENERATION SYSTEM"<<endl;
    while(true){
        cout<<endl;
        cout<<"1. Add Student Marks"<<endl;
        cout<<"2. Show All Marksheets"<<endl;
        cout<<"3. Search by Roll No"<<endl;
        cout<<"4. Exit"<<endl;
        cout<<"Enter choice: ";
        cin>>choice;
        if(choice==1){
            cout<<"Enter Roll No: ";
            cin>>roll[count];
            cout<<"Enter Name: ";
            cin>>name[count];
            cout<<"Enter marks of 5 subjects (out of 100 each):"<<endl;
            cout<<"Subject 1: ";
            cin>>sub1[count];
            cout<<"Subject 2: ";
            cin>>sub2[count];
            cout<<"Subject 3: ";
            cin>>sub3[count];
            cout<<"Subject 4: ";
            cin>>sub4[count];
            cout<<"Subject 5: ";
            cin>>sub5[count];
            total[count] = sub1[count]+sub2[count]+sub3[count]+sub4[count]+sub5[count];
            percentage[count] = total[count]/5;
            // basic grading logic
            if(percentage[count]>=90){
                grade[count]="A+";
            }
            else if(percentage[count]>=80){
                grade[count]="A";
            }
            else if(percentage[count]>=70){
                grade[count]="B";
            }
            else if(percentage[count]>=60){
                grade[count]="C";
            }
            else if(percentage[count]>=40){
                grade[count]="D";
            }
            else{
                grade[count]="Fail";
            }
            count=count+1;
            cout<<"Marksheet generated successfully!"<<endl;
        }
        if(choice==2){
            if(count==0){
                cout<<"No records yet"<<endl;
            }
            else{
                for(int i=0;i<count;i++){
                    cout<<endl;
                    cout<<"-------- MARKSHEET --------"<<endl;
                    cout<<"Roll No: "<<roll[i]<<endl;
                    cout<<"Name: "<<name[i]<<endl;
                    cout<<"Subject 1: "<<sub1[i]<<endl;
                    cout<<"Subject 2: "<<sub2[i]<<endl;
                    cout<<"Subject 3: "<<sub3[i]<<endl;
                    cout<<"Subject 4: "<<sub4[i]<<endl;
                    cout<<"Subject 5: "<<sub5[i]<<endl;
                    cout<<"Total: "<<total[i]<<endl;
                    cout<<"Percentage: "<<percentage[i]<<endl;
                    cout<<"Grade: "<<grade[i]<<endl;
                    cout<<"----------------------------"<<endl;
                }
            }
        }
        if(choice==3){
            int sroll;
            cout<<"Enter Roll No to search: ";
            cin>>sroll;
            int found=0;
            for(int i=0;i<count;i++){
                if(roll[i]==sroll){
                    cout<<endl;
                    cout<<"-------- MARKSHEET --------"<<endl;
                    cout<<"Roll No: "<<roll[i]<<endl;
                    cout<<"Name: "<<name[i]<<endl;
                    cout<<"Subject 1: "<<sub1[i]<<endl;
                    cout<<"Subject 2: "<<sub2[i]<<endl;
                    cout<<"Subject 3: "<<sub3[i]<<endl;
                    cout<<"Subject 4: "<<sub4[i]<<endl;
                    cout<<"Subject 5: "<<sub5[i]<<endl;
                    cout<<"Total: "<<total[i]<<endl;
                    cout<<"Percentage: "<<percentage[i]<<endl;
                    cout<<"Grade: "<<grade[i]<<endl;
                    cout<<"----------------------------"<<endl;
                    found=1;
                }
            }
            if(found==0){
                cout<<"Roll No not found"<<endl;
            }
        }
        if(choice==4){
            cout<<"Exiting..."<<endl;
            break;
        }
    }
    return 0;
}
