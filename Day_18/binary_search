#include<iostream>
using namespace std;
int main(){
    int n;
    cin>>n;
    int a[n];
    for(int i=0;i<n;i++){
        cin>>a[i];
    }
    int k;
    cin>>k;
    int flag=0;
    int low=0;
    int high=n-1;
    while(low<=high){
        int mid=(low+high)/2;
        if(a[mid]==k){
            flag=1;
            cout<<"element found at "<<mid<<" index";
            break;
        }
        else if(a[mid]>k){
            high=mid-1;
        }
        else low=mid+1;
    }
    if(flag==0){
        cout<<"element not found";
    }
}
